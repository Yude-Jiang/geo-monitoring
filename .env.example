# ─── LLM Provider ───────────────────────────────────────────────────────────
# Which LLM to use for server-side evaluation. Options: "gemini" (default) | "deepseek"
LLM_PROVIDER=gemini

# ─── Gemini (default evaluator) ─────────────────────────────────────────────
# Get yours from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── DeepSeek (alternative evaluator) ───────────────────────────────────────
# Required when LLM_PROVIDER=deepseek. Get your key from https://platform.deepseek.com
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
# Optional: override the default DeepSeek endpoint
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ─── Firebase (client-side) ──────────────────────────────────────────────────
# Copy values from your Firebase project console → Project Settings → Your apps
# These are exposed to the browser bundle; security is enforced by Firestore rules.
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="your_firestore_database_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_MEASUREMENT_ID=""

# ─── Application ────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─── Playwright Chrome Scraper ──────────────────────────────────────────────
# Directory where the Chrome persistent profile is stored.
# Default: .chrome-data (inside project root)
CHROME_DATA_DIR=.chrome-data

# Run Chrome in headless mode (no visible window).
# Set to "false" (default) for first-time setup so you can log into AI platforms.
# Set to "true" once sessions are saved for background operation.
HEADLESS=false

# ─── First-Time Setup Instructions ────────────────────────────────────────
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in your LLM API key (GEMINI_API_KEY or DEEPSEEK_API_KEY) and all VITE_FIREBASE_* values
# 3. Run: npm run dev
# 4. Click "执行监测" in the app
# 5. A Chrome window will open. Log into any AI platform that isn't logged in yet.
# 6. The session is saved. Future runs reuse it automatically.
# 7. (Optional) Once all platforms are logged in, set HEADLESS=true for silent operation.
