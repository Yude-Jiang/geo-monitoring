# ─── Required ──────────────────────────────────────────────────────────────
# Gemini API Key: used by the server-side evaluator to analyze AI responses.
# Get yours from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── Application ────────────────────────────────────────────────────────────
# The URL where this app is hosted (used for OAuth callbacks etc.)
APP_URL="http://localhost:3000"

# ─── Playwright Chrome Scraper ──────────────────────────────────────────────
# Directory where the Chrome persistent profile is stored.
# A new profile folder will be created here on first run.
# Default: .chrome-data (inside project root)
CHROME_DATA_DIR=.chrome-data

# Run Chrome in headless mode (no visible window).
# Set to "false" (default) for first-time setup so you can log into AI platforms.
# Set to "true" once sessions are saved for background operation.
# Default: false
HEADLESS=false

# ─── First-Time Setup Instructions ────────────────────────────────────────
# 1. Copy this file to .env:  copy .env.example .env
# 2. Fill in your GEMINI_API_KEY above
# 3. Run: npm run dev
# 4. Click "执行监测" in the app
# 5. A Chrome window will open. Log into any AI platform that isn't logged in yet.
# 6. The session is saved. Future runs reuse it automatically.
# 7. (Optional) Once all platforms are logged in, set HEADLESS=true for silent operation.
