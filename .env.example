# ─── Required ──────────────────────────────────────────────────────────────
# DeepSeek API Key: used by the server-side evaluator to analyze AI responses.
# Get yours from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# ─── Application ────────────────────────────────────────────────────────────
# The URL where this app is hosted.
APP_URL="http://localhost:3000"

# ─── Playwright Chrome Scraper ──────────────────────────────────────────────
CHROME_DATA_DIR=.chrome-data
HEADLESS=false

# ─── SQLite Data Directory ──────────────────────────────────────────────────
# Where the SQLite database and screenshot files are stored.
# On VM: a persistent local path, e.g. /var/lib/geo-monitoring/data
# On Cloud Run: a mounted GCS FUSE path, e.g. /data
DATA_DIR=data

# ─── Initial Admin User ─────────────────────────────────────────────────────
# On first startup, an admin user is created from these values.
# After first run, users can be managed via the login/register UI.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme123

# ─── Local Dev Setup ───────────────────────────────────────────────────────
# 1. Copy this file to .env:  copy .env.example .env
# 2. Fill in your DEEPSEEK_API_KEY above
# 3. Run: npm run dev
# 4. Open http://localhost:8080, register a new user or login as admin
# 5. Click "执行监测" — Chrome opens, log into AI platforms manually
# 6. Future runs reuse the Chrome session. Set HEADLESS=true for silent mode.

# ─── Cloud Run Deployment ───────────────────────────────────────────────────
# gcloud run deploy geo-monitoring \
#   --image gcr.io/PROJECT_ID/geo-monitoring \
#   --platform managed --port 8080 \
#   --set-env-vars "DEEPSEEK_API_KEY=sk-xxx,HEADLESS=true,APP_URL=https://xxx.run.app,NODE_ENV=production,ADMIN_USER=admin,ADMIN_PASSWORD=xxx" \
#   --add-volume name=data,type=cloud-storage,bucket=YOUR_BUCKET \
#   --add-volume-mount volume=data,mount-path=/data
#
# ⚠️  Cloud Run is stateless. Mount a Cloud Storage volume to /data
#     for SQLite + screenshots to persist across deployments.
